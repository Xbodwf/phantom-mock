{
  "name": "phantom-mock",
  "version": "1.0.0",
  "description": "Phantom Mock - OpenAI API Mock Server with frontend input",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:frontend": "vite",
    "dev:all": "concurrently \"pnpm dev\" \"pnpm dev:frontend\"",
    "build": "vite build",
    "build:frontend": "vite build",
    "build:backend": "tsc -p tsconfig.backend.json",
    "build:all": "concurrently \"pnpm build:backend\" \"pnpm build:frontend\"",
    "start": "tsx src/index.ts",
    "lint": "eslint src/frontend",
    "migrate": "tsx src/scripts/migrate.ts",
    "migrate:uids": "tsx src/scripts/migrate-user-uids.ts",
    "seed:admin": "tsx src/scripts/seed-admin.ts"
  },
  "keywords": [
    "openai",
    "mock",
    "phantom",
    "proxy"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@emailjs/nodejs": "^5.0.2",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@fontsource/lexend": "^5.2.11",
    "@fontsource/noto-sans-sc": "^5.2.9",
    "@monaco-editor/react": "^4.6.0",
    "@mui/icons-material": "^7.3.9",
    "@mui/material": "^7.3.8",
    "@mui/system": "^7.3.8",
    "axios": "^1.7.7",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.3.1",
    "express": "^4.21.2",
    "i18next": "^25.8.18",
    "i18next-browser-languagedetector": "^8.2.1",
    "js-tiktoken": "^1.0.21",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^0.469.0",
    "mongodb": "^7.1.0",
    "multer": "^2.1.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-i18next": "^16.5.8",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.13.1",
    "remark-gfm": "^4.0.1",
    "uuid": "^11.1.0",
    "vm2": "^3.10.5",
    "ws": "^8.18.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@swc/core": "^1.15.21",
    "@types/express": "^5.0.1",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.15.19",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitejs/plugin-react-swc": "^4.3.0",
    "concurrently": "^9.1.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1"
  }
}
